{
  "name": "tinycad",
  "productName": "TinyCAD",
  "version": "4.0.2",
  "description": "TinyCAD circuit editor",
  "author": {
    "name": "Matt Pyne",
    "email": "admin@tinycad.net"
  },
  "copyright": "Copyright (c) 2026 Matt Pyne",
  "license": "GPL-3.0-only",
  "main": "electron/electron.js",
  "targets": {
    "main": false
  },
  "type": "module",
  "scripts": {
    "start:ga": "cross-env TARGET_SYSTEM=google parcel index-ga.html",
    "start:fs": "cross-env TARGET_SYSTEM=filesystem parcel index-fs.html",
    "build:ga": "rimraf dist .parcel-cache && cross-env TARGET_SYSTEM=google parcel build index-ga.html --no-cache --public-url /ga/ && rimraf --glob 'dist/*.map'",
    "build:fs": "rimraf dist .parcel-cache && cross-env TARGET_SYSTEM=filesystem parcel build index-fs.html --no-cache --public-url /fs/ && rimraf --glob 'dist/*.map'",
    "check:i18n": "node scripts/check-translations.mjs",
    "dev": "concurrently -k \"npm run start:electron\" \"npm:electron\"",
    "dist": "rimraf dist .parcel-cache release && node scripts/dist.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "setup:test-appx": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-test-appx-cert.ps1",
    "dist:test-appx": "npm run setup:test-appx && npm run dist -- --win appx --test-appx",
    "start:electron": "cross-env TARGET_SYSTEM=electron parcel index-electron.html",
    "build:electron": "rimraf dist .parcel-cache && cross-env TARGET_SYSTEM=electron parcel build index-electron.html --no-cache --no-source-maps --public-url ./",
    "electron": "wait-on tcp:1234 && electron ."
  },
  "build": {
    "appId": "com.tinycad.app",
    "productName": "TinyCAD",
    "appx": {
      "backgroundColor": "transparent",
      "publisherDisplayName": "TinyCAD.net",
      "identityName": "TinyCAD.net.TinyCAD",
      "publisher": "${env.APPX_PUBLISHER}"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "icon": "assets/TinyCAD.png",
    "win": {
      "artifactName": "${productName} Windows Setup ${version}.${ext}",
      "icon": "assets/TinyCAD.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "forceCodeSigning": false
    },
    "linux": {
      "artifactName": "${name}_linux_${version}_${arch}.${ext}",
      "icon": "assets/TinyCAD.png",
      "fileAssociations": [
        {
          "ext": "dsn",
          "name": "TinyCAD Design",
          "description": "TinyCAD Design File",
          "icon": "assets/TinyCAD File.png",
          "role": "Editor"
        },
        {
          "ext": "tclib",
          "name": "TinyCAD Library",
          "description": "TinyCAD Component Library",
          "icon": "assets/TinyCAD Lib.png",
          "role": "Editor"
        }
      ],
      "target": [
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "armv7l",
            "arm64"
          ]
        }
      ]
    },
    "mac": {
      "artifactName": "${productName}-macos-${version}-${arch}.${ext}",
      "icon": "assets/TinyCAD.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "dsn",
        "name": "TinyCAD Design",
        "description": "TinyCAD Design File",
        "icon": "assets/TinyCAD File",
        "role": "Editor"
      },
      {
        "ext": "tclib",
        "name": "TinyCAD Library",
        "description": "TinyCAD Component Library",
        "icon": "assets/TinyCAD Lib",
        "role": "Editor"
      }
    ]
  },
  "dependencies": {
    "@fluentui/react-components": "^9.72.10",
    "@fluentui/react-icons": "^2.0.317",
    "blob-stream": "^0.1.3",
    "common-xml-features": "^2.1.9",
    "electron-is-dev": "^3.0.1",
    "electron-store": "^10.0.1",
    "file-saver": "^2.0.5",
    "fixed-data-table-2": "^1.2.2",
    "i18next": "^25.8.13",
    "i18next-resources-to-backend": "^1.2.1",
    "iconv-lite": "^0.7.2",
    "immutability-helper": "3.0.2",
    "md5": "2.2.1",
    "pdfkit": "^0.13.0",
    "react": "^18.3.1",
    "react-color": "2.18.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-redux": "^7.2.1",
    "redux": "^4.0.5",
    "redux-thunk": "^2.3.0",
    "redux-undo": "^1.0.1",
    "sql.js": "1.6.2",
    "svg-to-pdfkit": "^0.1.8"
  },
  "devDependencies": {
    "@parcel/transformer-image": "^2.16.4",
    "@parcel/transformer-sass": "^2.16.4",
    "@types/blob-stream": "^0.1.30",
    "@types/file-saver": "^2.0.3",
    "@types/fixed-data-table-2": "^0.8.6",
    "@types/md5": "^2.2.0",
    "@types/node": "13.11.1",
    "@types/pdfkit": "^0.12.2",
    "@types/react": "^18.3.27",
    "@types/react-color": "^3.0.4",
    "@types/react-dom": "^18.3.7",
    "@types/react-redux": "^7.1.9",
    "@types/sql.js": "^1.4.3",
    "@types/svg-to-pdfkit": "^0.1.0",
    "@typescript-eslint/eslint-plugin": "^3.10.1",
    "@typescript-eslint/parser": "^3.10.1",
    "assert": "^2.1.0",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "cssnano": "^7.1.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2",
    "eslint": "^7.8.1",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-prettier": "^3.1.4",
    "events": "^3.3.0",
    "parcel": "^2.16.4",
    "path-browserify": "^1.0.1",
    "png2icons": "^2.0.1",
    "prettier": "^2.1.1",
    "process": "^0.11.10",
    "rimraf": "^5.0.10",
    "sharp": "^0.34.4",
    "sass": "^1.26.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "typescript": "5.7.3",
    "util": "^0.12.5",
    "vm-browserify": "^1.1.2",
    "wait-on": "^8.0.2"
  },
  "private": true,
  "alias": {
    "crypto": false
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}